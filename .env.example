# ── Quantum Nexus v9 — Variables de entorno ──────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees .env con valores reales.

# Entorno de ejecución: PAPER (default, seguro) | LIVE (requiere HitL + 2FA)
ENV=PAPER

# Secreto HMAC para firma/verificación de señales (mínimo 32 bytes aleatorios)
HMAC_SECRET=cambia_esto_por_un_secreto_seguro_de_32_bytes_o_mas

# 2FA simulado para transición PAPER→LIVE (sólo en ENV=LIVE)
TWO_FA_CODE=

# Símbolos a tradear vía Binance WebSocket (vacío = modo demo con ticks sintéticos)
# Ejemplos: BTCUSDT  |  BTCUSDT,ETHUSDT,SOLUSDT
SYMBOLS=BTCUSDT

# Stream tipo: aggTrade (micro-trades) | kline_1m | kline_5m | kline_1h
STREAM_TYPE=kline_1m

# ── Binance REST (órdenes reales) ────────────────────────────────────────────
# Sin estas claves el sistema opera en modo mock (PAPER_FILL sin red).
# Usa claves de TESTNET para PAPER; claves de mainnet solo con ENV=LIVE + HitL.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Capital total en USDT y tamaño máximo de posición por trade
CAPITAL_USDT=100.0
NOTIONAL_USDT=10.0

# Supabase (telemetría inmutable)
SUPABASE_URL=
SUPABASE_KEY=

# Telegram (alertas críticas)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
