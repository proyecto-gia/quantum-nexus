# ── Quantum Nexus v9 — Variables de entorno ──────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees .env con valores reales.

# Entorno de ejecución: PAPER (default, seguro) | LIVE (requiere HitL + 2FA)
ENV=PAPER

# Secreto HMAC para firma/verificación de señales (mínimo 32 bytes aleatorios)
HMAC_SECRET=cambia_esto_por_un_secreto_seguro_de_32_bytes_o_mas

# 2FA simulado para transición PAPER→LIVE (sólo en ENV=LIVE)
TWO_FA_CODE=

# Supabase (telemetría inmutable)
SUPABASE_URL=
SUPABASE_KEY=

# Telegram (alertas críticas)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
